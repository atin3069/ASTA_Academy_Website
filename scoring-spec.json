      "format": "ASTA Academy reports a 30-point range, not a single number, to reflect estimation uncertainty.",
      "calculation": "Output range = [estimated_score - 15, estimated_score + 15]",
      "example": "If estimated_score = 640, report '625 - 655'"
    }
  },
  "diagnostic_report_structure": {
    "sections": [
      {
        "section": "header",
        "fields": [
          "student_name",
          "test_id",
          "date_completed",
          "time_spent_minutes"
        ]
      },
      {
        "section": "overall_performance",
        "fields": [
          "estimated_sat_math_score_range",
          "total_questions_correct",
          "total_questions_attempted",
          "module_1_correct",
          "module_2_correct",
          "module_2_variant_assigned",
          "percent_correct_overall"
        ]
      },
      {
        "section": "domain_breakdown",
        "for_each_domain": [
          "Algebra",
          "Advanced Math",
          "Problem-Solving and Data Analysis",
          "Geometry and Trigonometry"
        ],
        "fields": [
          "questions_in_domain",
          "questions_correct",
          "percent_correct",
          "performance_level (Strong / On-Track / Needs-Work / Critical-Gap)"
        ]
      },
      {
        "section": "skill_level_breakdown",
        "comment": "For each subtopic the student missed questions in, show the skill and link to relevant practice bank questions.",
        "fields_per_skill": [
          "domain",
          "subtopic",
          "skill_tag",
          "questions_seen",
          "questions_missed",
          "recommended_practice_question_ids (link to ASTA practice bank)"
        ]
      },
      {
        "section": "time_analysis",
        "fields": [
          "module_1_time_used_minutes",
          "module_2_time_used_minutes",
          "average_seconds_per_question",
          "pacing_assessment (Too-Fast / On-Pace / Too-Slow)"
        ]
      },
      {
        "section": "recommendations",
        "comment": "Auto-generated based on performance pattern. Top 3 weakest skills with direct links to practice content.",
        "format": "ranked_list_of_3_to_5_recommendations"
      }
    ]
  },
  "performance_level_thresholds": {
    "Strong": {
      "min_percent_correct": 85,
      "description": "Mastery achieved. Maintain with periodic review."
    },
    "On-Track": {
      "min_percent_correct": 65,
      "max_percent_correct": 84,
      "description": "Solid foundation. Focus on harder questions in this area."
    },
    "Needs-Work": {
      "min_percent_correct": 40,
      "max_percent_correct": 64,
      "description": "Foundational gaps. Prioritize practice in this area."
    },
    "Critical-Gap": {
      "max_percent_correct": 39,
      "description": "Significant weakness. Full review of subtopic recommended."
    }
  },
  "pacing_thresholds": {
    "Too-Fast": {
      "max_seconds_per_question": 60,
      "interpretation": "May be rushing. Re-check work for careless errors."
    },
    "On-Pace": {
      "min_seconds_per_question": 60,
      "max_seconds_per_question": 110,
      "interpretation": "Healthy pacing for accuracy."
    },
    "Too-Slow": {
      "min_seconds_per_question": 110,
      "interpretation": "Risk of running out of time. Practice timed drills."
    }
  },
  "implementation_notes": {
    "calibration_disclaimer": "Score estimates are based on weighted-correct-answer modeling, not the College Board's Item Response Theory (IRT) calibration. ASTA Academy should label all score predictions as 'estimated' or 'approximate' and recommend that students take official Bluebook practice tests for their most accurate score predictions.",
    "future_recalibration": "After ASTA Academy collects 200+ student records linking ASTA mock test scores to actual SAT scores, the score lookup tables should be recalibrated using regression analysis to improve accuracy.",
    "developer_handoff_checklist": [
      "Implement Module 1 timer (35:00 countdown)",
      "Implement weighted scoring at end of Module 1",
      "Implement routing logic at the threshold value of 18.0",
      "Load appropriate Module 2 variant based on routing result",
      "Implement Module 2 timer (35:00 countdown)",
      "Compute final score using the appropriate lookup table",
      "Generate diagnostic report using the structure above",
      "Link recommended practice questions back to the practice bank by skill_tag and question_id"
    ]
  }
}