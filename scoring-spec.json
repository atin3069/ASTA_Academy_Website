{
  "spec_name": "ASTA Academy SAT Math Mock Test - Scoring & Routing Specification",
  "version": "1.0",
  "description": "Complete specification for implementing adaptive 2-module mock tests with scoring and diagnostic reporting on the ASTA Academy platform.",
  "test_structure": {
    "total_questions": 44,
    "total_time_minutes": 70,
    "modules": [
      {
        "module": 1,
        "questions": 22,
        "time_minutes": 35,
        "difficulty": "mixed",
        "difficulty_distribution": {
          "Easy": 8,
          "Medium": 9,
          "Hard": 5
        }
      },
      {
        "module": 2,
        "questions": 22,
        "time_minutes": 35,
        "difficulty": "adaptive",
        "variants": {
          "easy_module_2": {
            "difficulty_distribution": {
              "Easy": 12,
              "Medium": 8,
              "Hard": 2
            },
            "max_score_cap": 600,
            "description": "Lower-difficulty questions; score range typically 200-600."
          },
          "hard_module_2": {
            "difficulty_distribution": {
              "Easy": 4,
              "Medium": 9,
              "Hard": 9
            },
            "max_score_cap": 800,
            "description": "Higher-difficulty questions; score range typically 500-800."
          }
        }
      }
    ],
    "domain_blueprint_per_module": {
      "comment": "Number of questions from each domain in each 22-question module.",
      "Algebra": {
        "min": 7,
        "max": 8
      },
      "Advanced Math": {
        "min": 7,
        "max": 8
      },
      "Problem-Solving and Data Analysis": {
        "min": 3,
        "max": 4
      },
      "Geometry and Trigonometry": {
        "min": 3,
        "max": 4
      }
    }
  },
  "module_1_scoring": {
    "method": "weighted_correct_answers",
    "weights": {
      "Easy": 1.0,
      "Medium": 1.5,
      "Hard": 2.0
    },
    "max_possible_weighted_score": 31.0,
    "comment": "Max = 8(1.0) + 9(1.5) + 5(2.0) = 8 + 13.5 + 10 = 31.5. Use 31.0 for clean cutoff math."
  },
  "routing_logic": {
    "rule": "If Module 1 weighted score >= routing_threshold, route to Hard Module 2. Otherwise, route to Easy Module 2.",
    "routing_threshold": 18.0,
    "routing_threshold_explanation": "Approximately 58% of max weighted score. This corresponds to a student correctly answering roughly 13-14 out of 22 questions with appropriate difficulty mix.",
    "implementation_pseudocode": "if (module_1_weighted_score >= 18.0) { route('hard_module_2'); } else { route('easy_module_2'); }"
  },
  "final_scoring": {
    "method": "lookup_table",
    "explanation": "Final scaled score (200-800) is determined by combining Module 1 weighted score and Module 2 weighted score, then applying a calibration table.",
